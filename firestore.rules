rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Produits : lecture publique, écriture admin authentifié uniquement
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Commandes : création publique (checkout), lecture/màj admin uniquement
    match /orders/{orderId} {
      allow create: if true;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // Métadonnées (catégories, config) : lecture publique
    match /metadata/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Règle par défaut : tout bloquer
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
