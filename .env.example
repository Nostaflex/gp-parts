# GP Parts — variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs.
# .env.local est ignoré par git (voir .gitignore : .env*.local)

# ─── Admin back-office (Basic Auth, obligatoire) ───
ADMIN_USER=admin
ADMIN_PASS=changeme

# ─── Firebase (Phase 3 : émulateur local) ───
NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true
NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-gp-parts

# ─── Firebase (Phase 4+ : cloud — décommenter et remplir) ───
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Phase 6+ : Resend (emails transactionnels) ───
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=commandes@gp-parts.example
# RESEND_ADMIN_EMAIL=stephane@example.com
